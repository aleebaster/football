UPDATE_INTERVAL=300

# Betting Analysis Parameters
MIN_EXPECTED_VALUE=5
MIN_PROFIT=3

# Cache Configuration
CACHE_TTL=300

# Scheduler Configuration
SCHEDULER_ENABLED=true

# Dashboard Configuration
